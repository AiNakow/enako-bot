# syntax=docker/dockerfile:1

FROM python:3.12-bookworm AS requirements_stage

WORKDIR /wheel

RUN python -m pip install --no-cache-dir pipx

COPY pyproject.toml requirements.txt /wheel/

RUN python -m pip wheel --wheel-dir=/wheel --no-cache-dir --requirement /wheel/requirements.txt
RUN python -m pipx run --no-cache nb-cli generate -f /tmp/bot.py


FROM python:3.12-slim-bookworm

WORKDIR /app

ENV TZ=Asia/Shanghai
ENV PYTHONPATH=/app
ENV PIP_NO_CACHE_DIR=1
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# System deps + Playwright Chromium runtime deps
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    ca-certificates \
    tzdata \
    curl \
    wget \
    gnupg \
    procps \
    net-tools \
    xvfb \
    ffmpeg \
    imagemagick \
    fonts-noto-color-emoji \
    fonts-wqy-zenhei \
    fonts-dejavu-core \
    xfonts-base \
    xfonts-scalable \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    libxshmfence1 \
 && rm -rf /var/lib/apt/lists/*

COPY --from=requirements_stage /tmp/bot.py /app/bot.py
COPY --from=requirements_stage /wheel /wheel

# Python deps + Playwright + Chromium
RUN pip install nonebot2 \
 && pip install --no-index --force-reinstall --find-links=/wheel -r /wheel/requirements.txt \
 && pip install playwright \
 && python -m playwright install chromium \
 && rm -rf /wheel

COPY . /app/

CMD ["python", "bot.py"]